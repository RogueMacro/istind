// file descriptors:
// stdout = 1

fn print(buf: &char) {
    std::write(1, buf, 1);
}

fn mod(dividend: i64, divisor: i64) -> i64 {
    n := dividend / divisor;
    return dividend - n * divisor;
}

fn write(fd: i64, buf: &char, count: i64);

fn exit(status: i64);

fn _mmap(addr: &(), len: i64, prot: i64, flags: i64, file_desc: i64, offset: i64);
